# ─────────────────────────────────────────────────────────────────────────────
# MedFlow EMR — Telehealth Extension Environment Variables
# Add these to your existing .env file
# ─────────────────────────────────────────────────────────────────────────────

# Daily.co — HIPAA-compliant video visits
# !! IMPORTANT: You MUST have a signed BAA with Daily.co before using in production
# Sign up at https://www.daily.co and enable HIPAA in account settings
# Get API key from https://dashboard.daily.co/developers
DAILY_API_KEY=
DAILY_DOMAIN=your-subdomain.daily.co

# MSO Dashboard Integration
# Used to verify provider state licensing before telehealth visits begin
# Set to your Railway MSO backend URL
MSO_DASHBOARD_URL=https://mso-backend.up.railway.app
MSO_DASHBOARD_API_KEY=   # Generate a dedicated API key in MSO dashboard admin settings

# Website CORS origin (for public self-scheduling and intake endpoints)
WEBSITE_ORIGIN=https://commonwealthsolutions.com
