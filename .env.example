# ── SECURITY (REQUIRED — change before going live!) ───────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# ── BILLING CRON SECRET ────────────────────────────────────────────────────────
# Used by the daily billing cron job to authenticate POST /api/cron/billing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BILLING_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite (local development — simple, no setup):
DATABASE_URL=sqlite:///./medflow.db

# PostgreSQL (Railway — paste the DATABASE_URL Railway gives you):
# DATABASE_URL=postgresql://user:password@host:5432/railway
# Note: Railway provides this automatically as an env var when you add
#       a PostgreSQL plugin — you don't need to set it manually on Railway.

# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
# Set to "production" on Railway to disable uvicorn auto-reload
ENVIRONMENT=development

# ── TOKEN EXPIRY ──────────────────────────────────────────────────────────────
TOKEN_EXPIRE_HOURS=8

# ── CORS (lock down in production) ────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for development
ALLOWED_ORIGINS=*
# Production example: ALLOWED_ORIGINS=https://your-app.railway.app

# ── LOCAL LLM (Ollama) ────────────────────────────────────────────────────────
# Install: https://ollama.ai  →  ollama pull llama3.1
# On Railway, AI notes will be unavailable unless you add an Ollama service.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── FAX INTEGRATION ───────────────────────────────────────────────────────────
FAX_NUMBER=+15550000000
# Option A — Twilio Programmable Fax (https://www.twilio.com/docs/fax)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B — SRFax (https://www.srfax.com/api-page)
# SRFAX_ACCOUNT_NUMBER=xxxxx
# SRFAX_PASSWORD=xxxxxxxx

# ── LABCORP INTEGRATION ───────────────────────────────────────────────────────
# LABCORP_CLIENT_ID=xxxx
# LABCORP_CLIENT_SECRET=xxxx
# LABCORP_ACCOUNT_NUMBER=xxxx

